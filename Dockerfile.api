FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt requirements-api.txt pyproject.toml README.md ./
COPY src ./src
COPY config ./config
COPY data ./data

RUN pip install --no-cache-dir -r requirements-api.txt

ENV APP_DEBUG=false

EXPOSE 8000

CMD ["uvicorn", "candidate_transformer.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
